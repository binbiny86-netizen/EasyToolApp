{
    "$schema":  "https://schema.tauri.app/config/2",
    "productName":  "得物 MuMu 采集",
    "version":  "0.1.2",
    "identifier":  "com.dewu.capture",
    "build":  {
                  "beforeDevCommand":  "npm run dev -- --host 127.0.0.1",
                  "devUrl":  "http://127.0.0.1:1420",
                  "beforeBuildCommand":  "npm run build",
                  "frontendDist":  "../dist"
              },
    "app":  {
                "windows":  [
                                {
                                    "title":  "得物 MuMu 采集",
                                    "width":  1180,
                                    "height":  760,
                                    "minWidth":  960,
                                    "minHeight":  640
                                }
                            ],
                "security":  {
                                 "csp":  null,
                                 "assetProtocol":  {
                                                       "enable":  true,
                                                       "scope":  [
                                                                     "**/*"
                                                                 ]
                                                   }
                             }
            },
    "bundle":  {
                   "active":  true,
                   "targets":  "all",
                   "icon":  [
                                "icons/32x32.png",
                                "icons/128x128.png",
                                "icons/128x128@2x.png",
                                "icons/icon.icns",
                                "icons/icon.ico"
                            ],
                   "resources":  {
                                     "../dewu_image_saver.py":  "dewu_image_saver.py"
                                 }
               }
}
